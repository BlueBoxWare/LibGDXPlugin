#
# Dog tree
#

# Alias definitions
import bark:"org.example.BarkTask"
import care:"org.example.CareTask"
import play:"org.example.PlayTask"
import mark:"org.example.MarkTask"
import walk:"org.example.WalkTask"
import rest:"org.example.RestTask"

# Tree definition (note that root is optional)
root
  selector
    parallel
      care urgentProb:0.8
      org.example.PlayTask # fully qualified task
    randomSelector
      untilSuccess  # find some trees to pee
        sequence
          bark times:"uniform,1,2"
          walk
          mark
      parallel policy:"selector"  # sleep with random timeout
        wait seconds:"triangular,2.5,5.5"
        rest
